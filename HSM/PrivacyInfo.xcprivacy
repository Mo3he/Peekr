<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Homelab Service Monitor does not track users and does not send data to third parties -->
    <key>NSPrivacyTracking</key>
    <false/>

    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- Data collected: none sent off-device -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- Required-reason APIs used by Homelab Service Monitor -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- UserDefaults: used to persist service list and settings on-device -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: Accessed to read/write on-device app data -->
                <string>CA92.1</string>
            </array>
        </dict>
        <!-- File timestamp: Application Support directory used for uptime data file -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- C617.1: Access timestamps of files the app created -->
                <string>C617.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
